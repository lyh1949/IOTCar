<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">


    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="30dp"
        android:layout_marginTop="30dp"
        android:id="@+id/operate_panel"
        >

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="连接"
            android:id="@+id/btn_connect"
            />

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="原地左转"
            android:id="@+id/btn_turn_left"
            />

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="原地右转"
            android:id="@+id/btn_turn_right"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/text_battery"
            android:text="电池电量：50%"
            android:layout_marginLeft="30dp"
            />

    </LinearLayout>

    <com.lyh.iotcar.ControlView
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:id="@+id/controlView"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_below="@id/operate_panel"
        android:layout_toLeftOf="@id/controlView"
        android:layout_margin="20dp"
        android:id="@+id/scrollview"
        android:background="@android:color/darker_gray"
        android:layout_height="match_parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:id="@+id/text_log"
            android:padding="10dp"
            />
    </ScrollView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/text_clear"
        android:text="Clear"
        android:layout_alignEnd="@id/scrollview"
        android:layout_alignTop="@id/scrollview"
        android:layout_margin="20dp"
        />


</RelativeLayout>